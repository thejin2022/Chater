DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ENABLE_CORS=False

DB_ENGINE=django.db.backends.postgresql
DB_NAME=chater_db
DB_USER=chater
DB_PASSWORD=chater
DB_HOST=db
DB_PORT=5432

CSRF_TRUSTED_ORIGINS=http://localhost:8080
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=1
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

REDIS_URL=redis://redis:6379/0

SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# Required keys: DJANGO_SECRET_KEY, DJANGO_ALLOWED_HOSTS, DB_ENGINE, DB_NAME,
# DB_USER, DB_HOST, DB_PORT, REDIS_URL

# -----------------------------
# Docker compose reference values
# -----------------------------
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
# CSRF_TRUSTED_ORIGINS=http://localhost:8080,https://your-domain.com
# JWT_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True

# Cross-origin frontend (only when frontend and backend are on different origins)
# ENABLE_CORS=True
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://frontend.your-domain.com
# CORS_ALLOW_CREDENTIALS=True
